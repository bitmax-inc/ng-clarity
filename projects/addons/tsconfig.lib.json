{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "es2020",
    "moduleResolution": "bundler",
    "types": ["jasmine"],
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@bitmax/clr-angular": ["../../dist/clr-angular/types/bitmax-clr-angular.d.ts"],
      "@bitmax/clr-angular/data/datagrid": ["../../dist/clr-angular/types/bitmax-clr-angular-data-datagrid.d.ts"],
      "@bitmax/clr-angular/forms": ["../../dist/clr-angular/types/bitmax-clr-angular-forms.d.ts"],
      "@bitmax/clr-angular/icon": ["../../dist/clr-angular/types/bitmax-clr-angular-icon.d.ts"],
      "@bitmax/clr-angular/layout/tabs": ["../../dist/clr-angular/types/bitmax-clr-angular-layout-tabs.d.ts"],
      "@bitmax/clr-angular/popover/common": ["../../dist/clr-angular/types/bitmax-clr-angular-popover-common.d.ts"],
      "@bitmax/clr-angular/popover/dropdown": ["../../dist/clr-angular/types/bitmax-clr-angular-popover-dropdown.d.ts"],
      "@bitmax/clr-angular/popover/signpost": ["../../dist/clr-angular/types/bitmax-clr-angular-popover-signpost.d.ts"],
      "@bitmax/clr-angular/progress/spinner": ["../../dist/clr-angular/types/bitmax-clr-angular-progress-spinner.d.ts"],
      "@bitmax/clr-angular/stepper": ["../../dist/clr-angular/types/bitmax-clr-angular-stepper.d.ts"],
      "@bitmax/clr-angular/utils": ["../../dist/clr-angular/types/bitmax-clr-angular-utils.d.ts"],
      "@bitmax/clr-angular/utils/loading": ["../../dist/clr-angular/types/bitmax-clr-angular-utils-loading.d.ts"],
      "@bitmax/clr-addons": ["./index.ts"],
      "@bitmax/clr-addons/*": ["./*"]
    }
  },
  "angularCompilerOptions": {
    "annotateForClosureCompiler": false,
    "preserveWhitespaces": true,
    "enableResourceInlining": true,
    "strictTemplates": true,
    "strictInjectionParameters": true,
    "skipTemplateCodegen": true,
    "strictMetadataEmit": true,
    "skipMetadataEmit": false,
    "fullTemplateTypeCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["test.ts", "**/*.spec.ts"]
}
